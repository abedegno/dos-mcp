{
  "name": "dos-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing a DOS emulator (js-dos) to AI agents — drive, observe, and inspect DOS programs.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "dos-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "puppeteer": "^23.0.0",
    "yauzl": "^3.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Jon Williams <jon@jonwilliams.org.uk>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abedegno/dos-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/abedegno/dos-mcp/issues"
  },
  "homepage": "https://github.com/abedegno/dos-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dos",
    "dosbox",
    "js-dos",
    "emulator",
    "retro",
    "ai-tools",
    "agent"
  ]
}
