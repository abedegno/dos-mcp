{
  "name": "dos-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing a DOS emulator (js-dos) to AI agents — drive, observe, and inspect DOS programs.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "dos-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "puppeteer": "^23.0.0",
    "yauzl": "^3.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/yauzl": "^2.10.3",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "keywords": ["mcp", "dos", "dosbox", "js-dos", "emulator", "retro"]
}
